*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI,sans-serif;
}

body{

margin:0;

background:#000;

background-size:cover;
background-position:center;

color:white;

padding-bottom:100;

overflow:hidden;

}

.overlay{

position:fixed;
top:0;
left:0;
right:0;
bottom:0;

background:rgba(0,30,60,.6);

z-index:0;

}

.container{

position:relative;
z-index:2;

padding:20px;
padding-bottom:0;

height:100vh;

overflow-y:auto;

box-sizing:border-box;

display:flex;
flex-direction:column;

}

#home{

position:fixed;

top:0;
left:0;

width:100%;
height:100%;

background:url("/bg.jpg") center center no-repeat;

background-size:cover;

background-position:center 50%;

background-repeat:no-repeat;

display:none;

opacity:0;

transform:translateY(60px);

transition:1s;

overflow:hidden;

}

.show-home{

display:block !important;

opacity:1 !important;

transform:translateY(0) !important;

}

.header{

position:sticky;

top:0;

z-index:100;

background:transparent;

}

#music-list{

overflow-y:auto;

padding-bottom:150px;

}

#loadingVideo{

position:fixed;

top:0;
left:0;

width:100%;
height:100%;

object-fit:cover;

z-index:-1;

}

.song-info {
flex: 1;
min-width: 0;
overflow: hidden;
}

.song-title {
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
}

.song-artist {
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
font-size: 12px;
opacity: 0.7;
}

.title{

font-size:32px;
font-weight:bold;
text-align:center;

margin-bottom:20px;

}

.search input{

width:100%;

padding:15px;

border:none;

border-radius:15px;

background:rgba(255,255,255,.15);

color:white;

margin-bottom:20px;

}

.music-card{

display:flex;

align-items:center;

gap:12px;

padding:15px;

margin-bottom:15px;

border-radius:18px;

background:rgba(255,255,255,.1);

backdrop-filter:blur(15px);

}

.cover {
width: 50px;
height: 50px;
flex-shrink: 0;
border-radius: 10px;
overflow: hidden;
}

.cover img {
width: 100%;
height: 100%;
object-fit: cover;
}

.info{

flex:1;

}

.song{

font-weight:bold;

}

.artist{

font-size:13px;

opacity:.7;

}

.fav{

background:none;

border:none;

color:gold;

font-size:24px;

}

.player{

position:fixed;

left:50%;
top:150px;

transform:translateX(-50%);

width:300px;
padding:12px;

background:rgba(10,25,60,.92);

backdrop-filter:blur(20px);

border-radius:25px;

z-index:999;

transition:.3s;

}

.player-show{

transform:translateY(0);

}

.player-info{

flex:1;

overflow:hidden;

}

#nowTitle{

font-size:15px;

font-weight:bold;

white-space:nowrap;

overflow:hidden;

text-overflow:ellipsis;

}

.now{

display:flex;

align-items:center;

gap:12px;

}

.disk{

width:60px;
height:60px;

min-width:60px;
min-height:60px;

border-radius:50%;

background:#2196f3;

display:flex;
justify-content:center;
align-items:center;

font-size:25px;

flex-shrink:0;

}

.controls{

display:flex;

justify-content:center;

gap:20px;

margin-top:10px;

}

.controls button{

width:48px;
height:48px;

border:none;

border-radius:50%;

background:#2196f3;

color:white;

font-size:20px;

}

input[type=range]{

width:100%;

margin-top:10px;

}

#welcome{

position:fixed;

top:0;
left:0;
right:0;
bottom:0;

display:flex;

justify-content:center;
align-items:center;

z-index:100;

}

.welcome-box{

width:90%;
max-width:350px;

padding:35px;

border-radius:25px;

background:transparent;

backdrop-filter:none;

text-align:center;

}

.logo{

font-size:60px;

margin-bottom:15px;

}

.welcome-box button{

margin-top:20px;

width:100%;

padding:15px;

border:none;

border-radius:15px;

background:#2196f3;

color:white;

font-size:18px;

}

.welcome-box{

animation:fade 1.2s;

}

@keyframes fade{

from{

opacity:0;
transform:translateY(30px);

}

to{

opacity:1;
transform:translateY(0);

}

}

.logo{

animation:glow 2s infinite;

}

@keyframes glow{

0%{

transform:scale(1);

}

50%{

transform:scale(1.1);

}

100%{

transform:scale(1);

}

}

.loading{

width:100%;

height:10px;

background:rgba(255,255,255,.1);

border-radius:20px;

overflow:hidden;

margin-top:20px;

margin-bottom:20px;

}

#bar{

width:0%;

height:100%;

background:linear-gradient(
90deg,
#2196f3,
#64b5f6
);

transition:.1s;

}

#start{

display:none;


}

.hide-welcome{

animation:hideWelcome .8s forwards;

}

@keyframes hideWelcome{

0%{

opacity:1;
transform:scale(1);

}

100%{

opacity:0;
transform:scale(1.3);

}

}

.music-card{

opacity:0;

transform:translateY(30px);

animation:card .8s forwards;

}

@keyframes card{

to{

opacity:1;

transform:translateY(0);

}

}

.menu{
display:flex;
gap:10px;
margin-bottom:15px;
}

.menu-card{
flex:1;
padding:12px;
text-align:center;
border-radius:15px;
background:rgba(255,255,255,.08);
backdrop-filter:blur(10px);
font-size:13px;
cursor:pointer;
transition:.3s;
}

.menu-card:hover{
background:#2196f3;
transform:scale(1.05);
}

#uploadFile{

width:100%;

margin-bottom:10px;

}

#uploadBtn{

width:100%;

padding:12px;

border:none;

border-radius:15px;

background:#2196f3;

color:white;

font-size:16px;

}

#mini{

width:35px;
height:35px;

border:none;

border-radius:50%;

background:transparent;

color:white;

}

.player-mini{

width:70px !important;
height:70px !important;

padding:0;

border-radius:50%;

overflow:hidden;

display:flex;
justify-content:center;
align-items:center;

}

.player-mini .player-info,
.player-mini .controls,
.player-mini input,
.player-mini #togglePlayer{

display:none;

}

#uploadArea{

position:fixed;

top:20px;
left:20px;

z-index:9999;

}

#uploadIcon{

width:50px;
height:50px;

border:none;

border-radius:50%;

background:#1e88e5;

color:white;

font-size:22px;

box-shadow:0 5px 15px rgba(0,0,0,.3);

}

.download{

background:none;

border:none;

color:#64b5f6;

font-size:22px;

margin-left:8px;

}

#settingBtn{

position:fixed;

top:15px;
right:15px;

width:50px;
height:50px;

background:transparent;

border:none;

outline:none;

box-shadow:none;

font-size:24px;

z-index:999;

cursor:pointer;

display:none;

}

#settingMenu{

position:fixed;

top:75px;
right:15px;

width:220px;

background:#222;

border-radius:15px;

padding:10px;

display:none;

z-index:999;

}

.settingItem{

padding:12px;

border-bottom:1px solid #444;

}
